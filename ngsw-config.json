{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/assets/icons/*.png",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "lazy-chunks",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": ["/**/*.js", "/**/*.css"]
      }
    },
    {
      "name": "static-assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(png|jpg|jpeg|gif|svg|ico|woff2?|eot|ttf)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-tenant",
      "urls": ["/api/client/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "10s"
      }
    },
    {
      "name": "api-tenant-auth",
      "urls": ["/sanctum/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 10,
        "maxAge": "5m",
        "timeout": "5s"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/api/**",
    "!/sanctum/**",
    "!/oauth/**"
  ],
  "navigationRequestStrategy": "freshness"
}
